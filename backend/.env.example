# BroxStudies backend — copy to .env and fill in secrets
#   cp .env.example .env

# ── LLM (at least one key required for AI tutor / question generation) ───────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

LLM_FALLBACK_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty for local SQLite in backend/data/persistence/auth.db
DATABASE_URL=
AUTH_DB_PATH=

# ── Auth & admin ─────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=change-this-auth-secret
ACCESS_TOKEN_EXPIRE_HOURS=168
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_USERNAME=broxstudiesadmin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SECRET=change-this-admin-secret

# ── Subscription & MoMo ───────────────────────────────────────────────────────
SUBSCRIPTION_PRICE_GHS=20
SUBSCRIPTION_MONTHS=3
MOMO_PAYMENT_NUMBER=0248317900

# ── Moolre (SMS + payment collection) ───────────────────────────────────────────
MOOLRE_VAS_KEY=
MOOLRE_SENDER_ID=BroxStudies
MOOLRE_API_BASE_URL=https://api.moolre.com
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_API_PUBKEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_PAYMENTS_ENABLED=true
MOOLRE_USE_SANDBOX=false
SMS_ENABLED=true

PUBLIC_APP_URL=http://localhost:5175

# ── CORS (JSON array) ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5175","http://localhost:5173","http://localhost:3000"]

# ── Paths (optional — defaults under backend/) ────────────────────────────────
PDF_UPLOAD_DIR=
DATA_DIR=
SITE_RESOURCE_DIR=
VECTOR_STORE_DIR=

# ── RAG / embeddings ─────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=text-embedding-3-small

# ── Question generation ───────────────────────────────────────────────────────
MAX_QUESTIONS=10
MIN_CONFIDENCE_SCORE=0.7

# ── Startup document loading ──────────────────────────────────────────────────
AUTO_LOAD_ON_STARTUP=true
LAZY_LOAD=true
SELECTIVE_LOAD=true
LOAD_SYLLABI_ONLY=false
MAX_INITIAL_SUBJECTS=5
