OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

LLM_FALLBACK_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

DATABASE_URL=sqlite:///./gh_shs.db
AUTH_DB_PATH=
AUTH_SECRET_KEY=change-this-auth-secret
ADMIN_SECRET=change-this-admin-secret
ACCESS_TOKEN_EXPIRE_HOURS=168
GOOGLE_CLIENT_ID=

# Subscription & MoMo
SUBSCRIPTION_PRICE_GHS=20
SUBSCRIPTION_MONTHS=3
MOMO_PAYMENT_NUMBER=0248317900

# Moolre SMS — get VAS key from app.moolre.com; register & approve sender ID first
MOOLRE_VAS_KEY=          # sent as header X-API-VASKEY (SMS/WhatsApp only, separate from API_KEY below)
MOOLRE_SENDER_ID=BroxStudies
MOOLRE_API_BASE_URL=https://api.moolre.com
SMS_ENABLED=true
OTP_EXPIRE_MINUTES=5

# Moolre Payment Collection — get from app.moolre.com developer settings
MOOLRE_API_USER=         # your Moolre username -> sent as header X-API-USER
MOOLRE_API_KEY=          # Private API Key -> sent as header X-API-KEY
MOOLRE_ACCOUNT_NUMBER=   # your Moolre account number -> sent as JSON body field "accountnumber"
MOOLRE_PAYMENT_ENABLED=true

# Paystack — disabled by default (set to true only for rollback)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_ENABLED=false
PUBLIC_APP_URL=http://localhost:5173

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

PDF_UPLOAD_DIR=
DATA_DIR=
SITE_RESOURCE_DIR=
VECTOR_STORE_DIR=

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=text-embedding-3-small

MAX_QUESTIONS=10
MIN_CONFIDENCE_SCORE=0.7

AUTO_LOAD_ON_STARTUP=true
LAZY_LOAD=true
SELECTIVE_LOAD=true
LOAD_SYLLABI_ONLY=false
MAX_INITIAL_SUBJECTS=5
