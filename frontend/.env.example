# BroxStudies frontend — copy to .env for local overrides
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_

# Dev server port (must match vite.config.ts if you change it here)
VITE_DEV_PORT=5175

# Optional: override API base URL (default: same origin + Vite proxy to :8000)
# VITE_API_BASE_URL=http://127.0.0.1:8000
